{
  "realm": "thaddeus",
  "enabled": true,
  "displayName": "Thaddeus",
  "sslRequired": "none",
  "registrationAllowed": false,
  "loginWithEmailAllowed": true,
  "roles": {
    "realm": [
      { "name": "thaddeus-admin", "description": "Full admin access" },
      { "name": "thaddeus-deployer", "description": "Can deploy and create releases" },
      { "name": "thaddeus-viewer", "description": "Read-only access" }
    ]
  },
  "clients": [
    {
      "clientId": "thaddeus-server",
      "enabled": true,
      "bearerOnly": true,
      "publicClient": false,
      "secret": "thaddeus-server-secret"
    },
    {
      "clientId": "thaddeus-ui",
      "enabled": true,
      "publicClient": true,
      "redirectUris": ["http://localhost:5173/*", "http://localhost:3000/*"],
      "webOrigins": ["http://localhost:5173", "http://localhost:3000"],
      "standardFlowEnabled": true
    },
    {
      "clientId": "thaddeus-agent",
      "enabled": true,
      "publicClient": false,
      "secret": "thaddeus-agent-secret",
      "serviceAccountsEnabled": true,
      "directAccessGrantsEnabled": false,
      "standardFlowEnabled": false
    }
  ],
  "users": [
    {
      "username": "admin",
      "email": "admin@thaddeus.local",
      "enabled": true,
      "credentials": [{ "type": "password", "value": "admin", "temporary": false }],
      "realmRoles": ["thaddeus-admin"]
    },
    {
      "username": "deployer",
      "email": "deployer@thaddeus.local",
      "enabled": true,
      "credentials": [{ "type": "password", "value": "deployer", "temporary": false }],
      "realmRoles": ["thaddeus-deployer"]
    }
  ]
}
